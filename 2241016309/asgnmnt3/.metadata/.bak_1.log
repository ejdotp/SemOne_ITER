package assignmentthree;

import java.util.Scanner;

/*Write a java program to calculate the monthly electricity bill. The tariff is given as
follows:

Price per unit Unit range
Rs. 3/- First 50 units
Rs. 4.80/- 50-200 units
Rs. 5.80/- 200-400 units
Rs. 6.20/- Above 400 units*/

public class QSIX {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		System.out.println("Input total units:");
		double un = sc.nextDouble();
		double a=3, b=4.80, c=5.80, d=6.20, bill;
		if(un<=50) {
			bill=un*a;
		}
		else if(un>50 && un<=200) {
			bill=un*a;
		}
		else if(un>200 && un<=400) {
			bill=(50*3)+((un-50)*4.8);
		}
		else(un<=50) {
			bill=(50*3)+(200*4.8)+((un-250)*4.8);
		}

	}

}

