		else if(un>50 && un<=200) {
			bill=(50*3)+((un-50)*4.8);
		}
		else if(un>200 && un<=400) {
			bill=(50*3)+(150*4.8)+((un-200)*5.8);
		}
		else(un<=50) {
			bill=(50*3)+(150*4.8)+(200*5.8)+((un-400)*6.2);
		}

	}

